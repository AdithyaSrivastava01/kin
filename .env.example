# ElevenLabs
ELEVENLABS_API_KEY=sk_...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Gemma on Vultr GPU
GEMMA_VULTR_URL=http://<VULTR_IP>:8088

# ngrok tunnel for voice gateway
# Either run ngrok manually and paste the URL here:
NGROK_URL=https://<your-domain>.ngrok.io
# OR let the gateway open the tunnel itself on startup (recommended for dev):
NGROK_AUTOSTART=false
NGROK_AUTHTOKEN=                # required if NGROK_AUTOSTART=true (get from ngrok.com dashboard)
NGROK_PORT=8000

# ASI:One (shared across agents)
ASI_ONE_API_KEY=...

# Agentverse (required for mailbox + publish_manifest on uAgent runners)
AGENTVERSE_API_KEY=...
INTAKE_SEED=<unique passphrase>
PROFILER_SEED=<unique passphrase>
FINDER_SEED=<unique passphrase>
MATCHER_SEED=<unique passphrase>
CALLER_SEED=<unique passphrase>
FINGERPRINT_SEED=<unique passphrase>

# OmegaClaw Telegram channel
TG_BOT_TOKEN=...

# MongoDB Atlas (Engineer 3 — clinics, patients, insurance_map)
# Create free M0 cluster at mongodb.com/atlas, allowlist 0.0.0.0/0,
# create db user with readWrite on `healthswarm`. Password should be
# alphanumeric (avoid @ : / ? # in URI without URL-encoding).
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/healthswarm?retryWrites=true&w=majority

# Dashboard relay (telemetry beacon target — defaults to localhost:3001)
TELEMETRY_RELAY_URL=http://localhost:3001/telemetry

# Voice gateway (swarm-caller → voice_gateway, defaults to localhost:8000)
VOICE_GATEWAY_URL=http://localhost:8000
VOICE_GW_TIMEOUT=10

# Optional host HTTP bridge for OmegaClaw container fallback
OMEGACLAW_BRIDGE_PORT=8015

# swarm-finder search parameters
FINDER_RADIUS_M=15000
FINDER_LIMIT=5

# swarm-matcher (LLM judge) token budget
MATCHER_MAX_TOKENS=512
MATCHER_WORKERS=8

# swarm-fingerprint token budget
FINGERPRINT_MAX_TOKENS=256

# swarm-caller concurrent call polling
CALL_POLL_INTERVAL_S=5
CALL_MAX_WAIT_S=150
MAX_FALLBACK_ATTEMPTS=3

# Fallback phone shown in beacons when a clinic has no phone in OSM data
DEMO_PHONE_FALLBACK=+1-555-DEMO
