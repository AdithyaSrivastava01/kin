# ElevenLabs
ELEVENLABS_API_KEY=sk_...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Gemma on Vultr GPU
GEMMA_VULTR_URL=http://<VULTR_IP>:8088

# ngrok tunnel for voice gateway
NGROK_URL=https://<your-domain>.ngrok.io

# ASI:One (shared across agents)
ASI_ONE_API_KEY=...

# MongoDB Atlas (Engineer 3 — clinics, patients, insurance_map)
# Create free M0 cluster at mongodb.com/atlas, allowlist 0.0.0.0/0,
# create db user with readWrite on `healthswarm`. Password should be
# alphanumeric (avoid @ : / ? # in URI without URL-encoding).
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/healthswarm?retryWrites=true&w=majority

# Dashboard relay (telemetry beacon target — defaults to localhost:3001)
TELEMETRY_RELAY_URL=http://localhost:3001/telemetry

# Voice gateway (swarm-caller → voice_gateway, defaults to localhost:8000)
VOICE_GATEWAY_URL=http://localhost:8000
VOICE_GW_TIMEOUT=10

# swarm-finder search parameters
FINDER_RADIUS_M=15000
FINDER_LIMIT=5

# swarm-matcher scoring weights (higher = more weight)
SCORE_INSURANCE=3
SCORE_LANGUAGE=2
SCORE_PROXIMITY_PER_KM=1
MATCHER_MAX_TOKENS=64

# Fallback phone shown in beacons when a clinic has no phone in OSM data
DEMO_PHONE_FALLBACK=+1-555-DEMO
